.DS_Store
local/**

# Code coverage reports (ignore generated data, keep badges and markdown reports)
coverage/cover_db/
coverage/html/
coverage/react/
!coverage/badges/
!coverage/*.md

# Playwright E2E test outputs
test-results/
playwright-report/
playwright/.cache/

# Build lock file (prevents concurrent builds)
.devbuild.lock

# Claude Code per-user config and ephemeral state
# (shared .claude/settings.json or .claude/agents/ stay committable)
.claude/settings.local.json
.claude/*.lock

# Visual regression screenshots (generated by tools/visual-regression.js)
screenshots/
